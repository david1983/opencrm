# Development Dockerfile with hot-reload
FROM node:20-alpine

WORKDIR /app

# Install dependencies
COPY package*.json ./
COPY client/package*.json ./client/
COPY server/package*.json ./server/
RUN npm ci

# Copy source files
COPY client/ ./client/
COPY server/ ./server/

# Set environment
ENV NODE_ENV=development
ENV PORT=5000

# Expose port
EXPOSE 5000

# Start server in development mode
WORKDIR /app
CMD ["npm", "run", "dev:server"]